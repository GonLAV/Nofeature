# ─── App ───────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_VERSION=v1

# ─── Database ──────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/warroom_dev
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ─── Redis ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ───────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── AI ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Slack ─────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_DEFAULT_CHANNEL=#incidents

# ─── Email ─────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG....
EMAIL_FROM=noreply@warroom.ai

# ─── PagerDuty ─────────────────────────────────────
PAGERDUTY_API_KEY=...
PAGERDUTY_SERVICE_ID=...

# ─── Rate Limiting ─────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Encryption ────────────────────────────────────
ENCRYPTION_KEY=change-me-32-char-encryption-key!

# ─── CORS ──────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ─── Stripe ────────────────────────────────────────
# Get these from console.stripe.com
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ─── App URL (used for Stripe redirect URLs) ───────
APP_URL=http://localhost:3000
